{
  "expo": {
    "name": "Ryu Admin",
    "slug": "ryu-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LOGO.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/LOGO.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/LOGO.jpg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "useNextNotificationsApi": true,
      "package": "com.manuelgs.ryuadmin"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#ff0000"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/LOGO.jpg"
    },
    "extra": {
      "eas": {
        "projectId": "b8ca2a53-c7fd-4dbd-8862-b87339dd8da9"
      }
    }
  }
}